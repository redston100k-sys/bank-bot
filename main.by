# ==========================================
# 🎲 ألعاب الحظ والمضاربة (تعمل بالكاش فقط + مؤقت 20 دقيقة)
# ==========================================
@bot.message_handler(func=lambda message: message.text and (message.text.startswith("حظ") or message.text.startswith("مضاربة")))
def games(message):
    user_id = message.from_user.id
    if not is_registered(user_id): return
    args = message.text.split()
    if len(args) < 2:
        bot.reply_to(message, "⚠️ حدد المبلغ كاش!")
        return
    try: amount = int(args[1])
    except: return
    if amount <= 0: return

    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    cursor.execute('SELECT cash, last_luck, last_speculate FROM users WHERE user_id = ?', (user_id,))
    cash, l_luck, l_spec = cursor.fetchone()
    now = datetime.now()
    
    if args[0] == "حظ":
        if l_luck and now < datetime.strptime(l_luck, '%Y-%m-%d %H:%M:%S') + timedelta(minutes=20):
            bot.reply_to(message, "❌ انتظر 20 دقيقة للعب الحظ مجدداً."); conn.close(); return
        if cash < amount: bot.reply_to(message, "❌ كاشك لا يكفي!"); conn.close(); return
        
        win = random.choice([True, False])
        new_cash = cash + amount if win else cash - amount
        cursor.execute('UPDATE users SET cash = ?, last_luck = ? WHERE user_id = ?', (new_cash, now.strftime('%Y-%m-%d %H:%M:%S'), user_id))
        bot.reply_to(message, f"🎲 {'🎉 ربحت وضاعفت الكاش!' if win else '📉 خسرت رهان الكاش!'}\nالمبلغ المعني: {amount} ريال.")
        
    elif args[0] == "مضاربة":
        if l_spec and now < datetime.strptime(l_spec, '%Y-%m-%d %H:%M:%S') + timedelta(minutes=20):
            bot.reply_to(message, "❌ انتظر 20 دقيقة للمضاربة مجدداً."); conn.close(); return
        if cash < amount: bot.reply_to(message, "❌ كاشك لا يكفي!"); conn.close(); return
        
        win = random.choice([True, False])
        new_cash = cash + int(amount * 1.5) if win else cash - amount
        cursor.execute('UPDATE users SET cash = ?, last_speculate = ? WHERE user_id = ?', (new_cash, now.strftime('%Y-%m-%d %H:%M:%S'), user_id))
        bot.reply_to(message, f"📈 {'🚀 نجحت المضاربة وربحت 150%!' if win else '💥 انهارت الأسهم وخسرت كاشك!'}")

    conn.commit()
    conn.close()
    check_and_apply_debts()

# ==========================================
# 🏦 عمليات البنك: إيداع (كل 6 ساعات للسلامة) وسحب مفتوح
# ==========================================
@bot.message_handler(func=lambda message: message.text and (message.text.startswith("إيداع") or message.text.startswith("سحب")))
def bank_system(message):
    user_id = message.from_user.id
    if not is_registered(user_id): return
    args = message.text.split()
    if len(args) < 2: return
    action, target = args[0], args[1]
    
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    cursor.execute('SELECT cash, bank, last_deposit FROM users WHERE user_id = ?', (user_id,))
    cash, bank, last_dep = cursor.fetchone()
    now = datetime.now()
    
    if action == "إيداع":
        if last_dep and now < datetime.strptime(last_dep, '%Y-%m-%d %H:%M:%S') + timedelta(hours=6):
            remaining = (datetime.strptime(last_dep, '%Y-%m-%d %H:%M:%S') + timedelta(hours=6)) - now
            bot.reply_to(message, f"🔐 مقفل! يمكنك الإيداع بالبنك مرة كل 6 ساعات لتأمين فلوسك من السرقة.\n⏳ متبقي: {remaining.seconds // 3600} ساعة و {(remaining.seconds % 3600) // 60} دقيقة.")
            conn.close()
            return
        amount = cash if target == "الكل" else int(target)
        if amount <= 0 or cash < amount: conn.close(); return
        cursor.execute('UPDATE users SET cash = cash - ?, bank = bank + ?, last_deposit = ? WHERE user_id = ?', (amount, amount, now.strftime('%Y-%m-%d %H:%M:%S'), user_id))
        bot.reply_to(message, f"🏦 أودعت {amount} ريال في البنك بنجاح وأصبحت محمية!")
        
    elif action == "سحب":
        amount = bank if target == "الكل" else int(target)
        if amount <= 0 or bank < amount: conn.close(); return
        cursor.execute('UPDATE users SET cash = cash + ?, bank = bank - ? WHERE user_id = ?', (amount, amount, user_id))
        bot.reply_to(message, f"💵 سحبت {amount} ريال كاش لجيبك!")
        
    conn.commit()
    conn.close()

# ==========================================
# 💸 أمر تحويل الأموال بالرد (من البنك للبنك مباشرة للأمان)
# ==========================================
@bot.message_handler(func=lambda message: message.text and message.text.startswith("تحويل"))
def transfer_money(message):
    sender_id = message.from_user.id
    if not message.reply_to_message:
        bot.reply_to(message, "❌ يجب الرد على رسالة الشخص للتحويل له!")
        return
    receiver_id = message.reply_to_message.from_user.id
    if sender_id == receiver_id: return
    if not is_registered(sender_id) or not is_registered(receiver_id): return
    
    args = message.text.split()
    if len(args) < 2: return
    try: amount = int(args[1])
    except: return
    if amount <= 0: return

    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    cursor.execute('SELECT bank FROM users WHERE user_id = ?', (sender_id,))
    s_bank = cursor.fetchone()[0]
    if s_bank < amount:
        bot.reply_to(message, "❌ رصيد بنكك لا يكفي للتحويل الرسمى!")
        conn.close()
        return
        
    cursor.execute('UPDATE users SET bank = bank - ? WHERE user_id = ?', (amount, sender_id))
    cursor.execute('UPDATE users SET bank = bank + ? WHERE user_id = ?', (amount, receiver_id))
    conn.commit()
    conn.close()
    bot.reply_to(message, f"💸 تم تحويل {amount} ريال بنكياً بنجاح إلى حساب {message.reply_to_message.from_user.first_name}!")

# ==========================================
# 🥷 أمر السرقة الاحترافي (من الكاش للكاش بالرد)
# ==========================================
@bot.message_handler(func=lambda message: message.text == "سرقة")
def steal_cash(message):
    thief_id = message.from_user.id
    if not message.reply_to_message:
        bot.reply_to(message, "❌ رد على رسالة الشخص لسرقته!")
        return
    victim_id = message.reply_to_message.from_user.id
    if thief_id == victim_id: return
    if not is_registered(thief_id) or not is_registered(victim_id): return

    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    cursor.execute('SELECT cash FROM users WHERE user_id = ?', (thief_id,))
    thief_cash = cursor.fetchone()[0]
    cursor.execute('SELECT cash FROM users WHERE user_id = ?', (victim_id,))
    victim_cash = cursor.fetchone()[0]

    if victim_cash <= 50:
        bot.reply_to(message, "🥷 الضحية طفران تماماً! كاشه لا يستحق عناء السرقة.")
        conn.close()
        return

    success = random.choice([True, False])
    if success:
        stolen = random.randint(10, int(victim_cash * 0.5))  # يسرق كحد أقصى 50% من كاش الضحية الحالي
        cursor.execute('UPDATE users SET cash = cash + ? WHERE user_id = ?', (stolen, thief_id))
        cursor.execute('UPDATE users SET cash = cash - ? WHERE user_id = ?', (stolen, victim_id))
        bot.reply_to(message, f"🥷 نجحت السرقة غسيل أموال فاشل!\n💰 سرقت بنجاح {stolen} ريال كاش من مخبأ {message.reply_to_message.from_user.first_name}!")
    else:
        penalty = random.randint(50, 300)
        penalty = min(penalty, thief_cash) if thief_cash > 0 else 0
        cursor.execute('UPDATE users SET cash = cash - ? WHERE user_id = ?', (penalty, thief_id))
        cursor.execute('UPDATE users SET cash = cash + ? WHERE user_id = ?', (penalty, victim_id))
        bot.reply_to(message, f"👮 كُشفت المحاولة وتم القبض عليك بالجرم المشهود!\n💸 دفعت تعويضاً قدره {penalty} ريال كاش من جيبك للضحية!")

    conn.commit()
    conn.close()
    check_and_apply_debts()

# ==========================================
# 🤝 نظام الدين التلقائي والمؤتمت بالكامل بالرد
# ==========================================
@bot.message_handler(func=lambda message: message.text and (message.text.startswith("دين") or message.text.startswith("سداد")))
def debt_system(message):
    check_and_apply_debts()
    user_id = message.from_user.id
    if not message.reply_to_message:
        bot.reply_to(message, "❌ يجب استخدام هذا الأمر بالرد على رسالة الشخص الآخر!")
        return
    other_id = message.reply_to_message.from_user.id
    if user_id == other_id: return
    if not is_registered(user_id) or not is_registered(other_id): return
    
    args = message.text.split()
    action = args[0]
    
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    if action == "دين":
        if len(args) < 2: return
        try: amount = int(args[1])
        except: return
        if amount <= 0: return
        
        # فحص إذا كان الطالب مديناً بالفعل لشخص آخر لمنع تكدس الديون
        cursor.execute('SELECT debt_id FROM debts WHERE debtor_id = ?', (user_id,))
        if cursor.fetchone():
            bot.reply_to(message, "❌ لديك سلف أو دين حالي في ذمتك! سدده أولاً قبل طلب دين جديد.")
            conn.close()
            return
            
        # الدائن يسلف من حساب البنك الخاص به للأمان
        cursor.execute('SELECT bank FROM users WHERE user_id = ?', (other_id,))
        creditor_bank = cursor.fetchone()[0]
        if creditor_bank < amount:
            bot.reply_to(message, "❌ هذا الشخص لا يملك السيولة الكافية في بنكه لإقراضك هذا المبلغ!")
            conn.close()
            return
            
        # إتمام عملية الدين
        now_str = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
        cursor.execute('UPDATE users SET bank = bank - ? WHERE user_id = ?', (amount, other_id))
        cursor.execute('UPDATE users SET cash = cash + ? WHERE user_id = ?', (amount, user_id))
        cursor.execute('INSERT INTO debts (debtor_id, creditor_id, amount, start_time) VALUES (?, ?, ?, ?)', (user_id, other_id, amount, now_str))
        bot.reply_to(message, f"🤝 تمت عملية السلف بنجاح!\n👤 استعرت {amount} ريال كاش من {message.reply_to_message.from_user.first_name}.\n⏳ معك 3 ساعات بالضبط لإرجاعها وإلا ستتضاعف وتتعرض لعقوبة السحب والمصادرة التلقائية الكلية!")
        
    elif action == "سداد":
        # تسديد الدين يتم بالرد على الدائن الأصلي
        cursor.execute('SELECT debt_id, amount, is_doubled, remaining_penalty FROM debts WHERE debtor_id = ? AND creditor_id = ?', (user_id, other_id))
        debt_res = cursor.fetchone()
        if not debt_res:
            bot.reply_to(message, "❌ ليس لهذا الشخص أي مستحقات دين مسجلة بذمتك حالياً!")
            conn.close()
            return
            
        debt_id, amount, is_doubled, rem_penalty = debt_res
        required = (amount * 2) if is_doubled else amount
        if rem_penalty > 0: required = rem_penalty
        
        cursor.execute('SELECT cash FROM users WHERE user_id = ?', (user_id,))
        my_cash = cursor.fetchone()[0]
        
        if my_cash < required:
            bot.reply_to(message, f"❌ كاش جيبك لا يكفي للسداد التام! مطلوب منك كاش صافي قدره: {required} ريال.")
            conn.close()
            return
            
        # خصم السداد وإغلاق الدين
        cursor.execute('UPDATE users SET cash = cash - ? WHERE user_id = ?', (required, user_id))
        cursor.execute('UPDATE users SET bank = bank + ? WHERE user_id = ?', (required, other_id))
        cursor.execute('DELETE FROM debts WHERE debt_id = ?', (debt_id,))
        bot.reply_to(message, f"🎉 كفو! أرجعت الأمانة لأصحابها وتم سداد المستحقات بالكامل برصيد {required} ريال.")
        
    conn.commit()
    conn.close()

if __name__ == '__main__':
    # تشغيل نظام الاستضافة المستقر لـ Render بالخلفية ليعمل 24 ساعة دون نوم
    Thread(target=run_web_server, daemon=True).start()
    bot.polling(none_stop=True)
