    {"job": "رقاصه 💃", "min": 3000, "max": 7000, "msg": "ايوا كذا دلعني!"},
    {"job": "مهندس", "min": 10000, "max": 30000, "msg": "طبيعي مهندس!"},
]

# ==========================================
# 🎮 الأوامر الأساسية وإنشاء الحساب
# ==========================================
@bot.message_handler(commands=['start'])
def start_cmd(message):
    bot.reply_to(message, "🏦 أهلاً بك في البنك المطوّر بالكامل!\nاكتب `إنشاء حساب` للبدء فوراً.")

@bot.message_handler(func=lambda message: message.text == "إنشاء حساب")
def create_account(message):
    user_id = message.from_user.id
    name = message.from_user.first_name
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    cursor.execute('SELECT has_account FROM users WHERE user_id = ?', (user_id,))
    result = cursor.fetchone()
    if result and result[0] == 1:
        bot.reply_to(message, "❌ حسابك نشط بالفعل!")
        conn.close()
        return
    gift = 1000
    if result:
        cursor.execute('UPDATE users SET has_account = 1, cash = ? WHERE user_id = ?', (gift, user_id))
    else:
        cursor.execute('INSERT INTO users VALUES (?, 1, ?, 0, None, None, None, None, None, None)', (user_id, gift))
    conn.commit()
    conn.close()
    bot.reply_to(message, f"🎉 تم فتح حسابك بنجاح وجيبك يحتوي {gift} ريال كاش!")

# ==========================================
# 📊 أمر رصيد الفلوس (ويقوم بالفحص التلقائي للدين)
# ==========================================
@bot.message_handler(func=lambda message: message.text == "فلوسي")
def my_money(message):
    check_and_apply_debts()  # تشغيل الفحص التلقائي للدين قبل عرض الرصيد
    user_id = message.from_user.id
    if not is_registered(user_id):
        bot.reply_to(message, "⚠️ سجل حسابك أولاً.")
        return
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    cursor.execute('SELECT cash, bank FROM users WHERE user_id = ?', (user_id,))
    cash, bank = cursor.fetchone()
    
    # فحص لو كان عليه أقساط دين متبقية تحت بند العقوبة المفتوحة
    cursor.execute('SELECT remaining_penalty FROM debts WHERE debtor_id = ? AND remaining_penalty > 0', (user_id,))
    penalty_res = cursor.fetchone()
    penalty_msg = f"\n⚠️ **تنبيه:** متأخر عن الدين ومطلوب سحب تلقائي مستمر لـ {penalty_res[0]} ريال!" if penalty_res else ""
    
    conn.close()
    bot.reply_to(message, f"📊 **رصيدك الحالي:**\n💵 كاش بجيبك: {cash} ريال\n🏦 بالبنك الآمن: {bank} ريال{penalty_msg}")

# ==========================================
# 💼 أمر الراتب المحدث (يسحب تلقائياً للدين لو متأخر)
# ==========================================
@bot.message_handler(func=lambda message: message.text == "راتب")
def get_salary(message):
    user_id = message.from_user.id
    if not is_registered(user_id): return
    
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    cursor.execute('SELECT last_salary, cash FROM users WHERE user_id = ?', (user_id,))
    last_sal, cash = cursor.fetchone()
    now = datetime.now()
    
    if last_sal and now < datetime.strptime(last_sal, '%Y-%m-%d %H:%M:%S') + timedelta(minutes=20):
        remaining = (datetime.strptime(last_sal, '%Y-%m-%d %H:%M:%S') + timedelta(minutes=20)) - now
        bot.reply_to(message, f"❌ انتظر {remaining.seconds // 60} دقيقة للراتب القادم.")
        conn.close()
        return
        
    job = random.choice(JOBS)
    salary = random.randint(job["min"], job["max"])
    cursor.execute('UPDATE users SET cash = ?, last_salary = ? WHERE user_id = ?', (cash + salary, now.strftime('%Y-%m-%d %H:%M:%S'), user_id))
    conn.commit()
    conn.close()
    
    bot.reply_to(message, f"💼 **{job['job']}**: {job['msg']}\n💰 نزل لك: +{salary} ريال كاش!")
    check_and_apply_debts()  # لو عليه دين متأخر، يتم سحب الراتب الجديد له فوراً لصالح الدائن

